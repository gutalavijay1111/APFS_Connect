# ── Database ────────────────────────────────────────────────────────────────
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=yourpassword
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=apfs

# ── Redis ────────────────────────────────────────────────────────────────────
# Used by Celery broker + backend
REDIS_URL=redis://localhost:6379/10

# ── App mode ────────────────────────────────────────────────────────────────
# debug | production
MODE=production

# ── Logging ─────────────────────────────────────────────────────────────────
CONSOLE_LOG_LEVEL=INFO
FILE_LOG_LEVEL=INFO
ENABLE_COLORS=false

# ── WhatsApp Business API ────────────────────────────────────────────────────
ACCESS_TOKEN=your_whatsapp_access_token
PHONE_NUMBER=your_phone_number_id
APAROKSHA_WHATSAPP_ACCOUNT_ID=your_whatsapp_account_id
VERSION=v21.0

# ── Webhook verification ─────────────────────────────────────────────────────
# Must match the token you set in Meta's webhook dashboard
VERIFY_TOKEN=your_webhook_verify_token

# ── Third-party integrations ─────────────────────────────────────────────────
TITAN_USERNAME=
TITAN_PASSWORD=
THIRD_PARTY_API_KEY=
WHATSAPP_API_TOKEN=
